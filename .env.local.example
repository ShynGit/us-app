# Pusher Channels — get these from https://pusher.com (free account)
# 1. Create a new Channels app
# 2. Copy the keys from the App Keys section

PUSHER_APP_ID=your_app_id
PUSHER_KEY=your_key
PUSHER_SECRET=your_secret
PUSHER_CLUSTER=your_cluster   # e.g. ap1, us2, eu

# These two are exposed to the browser (safe to expose)
NEXT_PUBLIC_PUSHER_KEY=your_key
NEXT_PUBLIC_PUSHER_CLUSTER=your_cluster
